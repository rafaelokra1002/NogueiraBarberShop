// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  password  String?
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

    // Relations
    appointments Appointment[]

    @@map("users")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  appointments Appointment[]

  @@map("clients")
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  duration    Int
  price       Float
  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  appointments Appointment[]
  appointmentItems AppointmentService[]

  @@map("services")
}


model Appointment {
  id          String            @id @default(cuid())
  date        DateTime
  time        String
  status      String            @default("SCHEDULED")
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
  
  barberId  String?
  barber    User?   @relation(fields: [barberId], references: [id])
  
  // New multi-service relation (all services including primary)
  services  AppointmentService[]

  @@map("appointments")
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId String
  service       Service     @relation(fields: [serviceId], references: [id])
  serviceId     String
  order         Int         @default(0)

  @@unique([appointmentId, serviceId])
  @@map("appointment_services")
}

model BusinessSettings {
  id                String   @id @default(cuid())
  businessName      String   @default("BarberPro")
  businessAddress   String   @default("Rua das Flores, 123 - Centro")
  businessPhone     String   @default("(11) 99999-9999")
  businessEmail     String   @default("contato@barberpro.com")
  openingHours      String   @default("08:00-18:30")
  workingDays       String   @default("1,2,3,4,5,6") // 0=Sunday, 1=Monday, etc.
  appointmentSlots  String   @default("30") // minutes
  maxAdvanceDays    Int      @default(30)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("business_settings")
}

model ClosedDay {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())

  @@map("closed_days")
}

model Transaction {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String
  date        DateTime
  type        String   // "income" or "expense"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("transactions")
}