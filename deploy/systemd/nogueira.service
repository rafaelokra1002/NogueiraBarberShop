[Unit]
Description=Nogueira Barber Shop API + SPA (Node)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/NogueiraBarberShop
Environment=NODE_ENV=production
Environment=PORT=3007
Environment=HOST=0.0.0.0
ExecStart=/usr/bin/npm run server
Restart=on-failure
RestartSec=5
# Opcional: se usar .env
# EnvironmentFile=/opt/NogueiraBarberShop/.env

[Install]
WantedBy=multi-user.target
