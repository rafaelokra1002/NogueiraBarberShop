# Frontend API base URL (optional)
# Em produção, deixe em branco para usar caminho relativo /api atrás do proxy reverso (Caddy/Nginx)
VITE_API_BASE_URL=

# Dev server / API interno
# Produção: manter Node somente em 127.0.0.1:3007 e expor apenas o proxy (443)
HOST=127.0.0.1
PORT=3007

# WhatsApp
WHATSAPP_AUTO_ON_CONFIRM=true
WHATSAPP_PROVIDER=meta
WHATSAPP_COUNTRY_CODE=55
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Twilio (opcional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
